# =============================================================================
# Sao chép file này thành `.env` và điền giá trị thật. KHÔNG commit file .env.
# =============================================================================

# --- Claude API (chỉ cần khi bật LLM extraction). Thiếu key -> tự fallback rule.
ANTHROPIC_API_KEY=

# --- Tóm tắt biên bản tuân thủ (tùy chọn; rule engine không cần key) --------
OPENAI_API_KEY=
GEMINI_API_KEY=
# deterministic | openai | gemini
OCRIDP_COMPLIANCE_SUMMARY_PROVIDER=deterministic
# Model ID chính thức của Gemini 3 Flash.
OCRIDP_COMPLIANCE_GEMINI_MODEL=gemini-3-flash-preview

# --- Ghi đè cấu hình runtime (tùy chọn) -------------------------------------
# Đường dẫn file cấu hình YAML (mặc định: configs/default.yaml)
OCRIDP_CONFIG=configs/default.yaml
# Thư mục dữ liệu (mặc định: data)
OCRIDP_DATA_DIR=data
# Mức log: DEBUG | INFO | WARNING | ERROR
OCRIDP_LOG_LEVEL=INFO

# --- Engine OCR mặc định (ghi đè configs/default.yaml: ocr.engine) ----------
# rapidocr | vietocr | paddle | easyocr | tesseract
OCRIDP_OCR_ENGINE=rapidocr

# --- Đường dẫn tới Tesseract (chỉ Windows-native, nếu không nằm trong PATH) --
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

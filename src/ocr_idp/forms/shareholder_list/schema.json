{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ocr-idp/shareholder_list",
  "title": "Danh sách người sở hữu chứng khoán",
  "type": "object",
  "properties": {
    "form_type": { "const": "shareholder_list" },
    "issuer_name": { "type": ["string", "null"], "description": "Tổ chức phát hành" },
    "security_symbol": { "type": ["string", "null"], "description": "Mã chứng khoán" },
    "report_date": { "type": ["string", "null"], "format": "date", "description": "Ngày chốt/báo cáo" },
    "shareholders": {
      "type": "array",
      "description": "Danh sách cổ đông (mỗi dòng 1 người)",
      "items": {
        "type": "object",
        "properties": {
          "no": { "type": ["integer", "null"], "description": "STT" },
          "full_name": { "type": "string", "description": "Họ và tên" },
          "id_number": { "type": ["string", "null"], "description": "Số CMND/CCCD" },
          "shares": { "type": ["integer", "null"], "minimum": 0, "description": "Số lượng cổ phần" },
          "ratio_percent": { "type": ["number", "null"], "description": "Tỷ lệ sở hữu (%)" }
        },
        "required": ["full_name", "shares"]
      }
    },
    "total_shares": { "type": ["integer", "null"], "minimum": 0 },
    "total_shareholders": { "type": ["integer", "null"], "minimum": 0 },
    "_meta": { "type": "object" }
  },
  "required": ["form_type", "shareholders"]
}
